# Copy to .env (git-ignored) and fill in. Do NOT commit real values.
#
# HANDBALL_DB_URL: Supabase Postgres, in SQLAlchemy+psycopg form. Use the
#   SESSION POOLER string (IPv4-friendly; the free-tier direct connection is
#   IPv6-only). Note the "+psycopg" driver suffix and the "postgres.<ref>" user.
#   Dashboard: top "Connect" button -> Session pooler -> URI, then rewrite the
#   leading "postgresql://" to "postgresql+psycopg://".
HANDBALL_DB_URL=postgresql+psycopg://postgres.<project-ref>:<DB-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://dabgpgjwvarojclnpptf.supabase.co

# Frontend (browser) key. The "Publishable key" (sb_publishable_...). Safe to
# expose publicly; RLS is what protects the data. Settings -> API Keys.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Backend-only key. The "Secret key" (sb_secret_...). Privileged, bypasses RLS;
# NEVER send to the browser. Only needed if the API calls Supabase admin/REST
# APIs -- our API talks to Postgres directly, so this is optional for now.
SUPABASE_SECRET_KEY=sb_secret_...

# JWT verification: this project uses ASYMMETRIC signing keys (Settings -> JWT
# Keys), so there is no shared HS256 secret to paste. api/auth.py will verify
# tokens against the public JWKS endpoint instead:
#   https://dabgpgjwvarojclnpptf.supabase.co/auth/v1/.well-known/jwks.json
